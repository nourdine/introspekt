{
   "name": "nourdine/introspekt",
   "type": "library",
   "description": "A library allowing the usage of class and methods annotations in json format",
   "keywords": [
      "json",
      "annotations"
   ],
   "license": "MIT",
   "authors": [
      {
         "name": "nourdine"
      }
   ],
   "require-dev": {
      "phpunit/phpunit": "^9.5"
   },
   "autoload": {
      "psr-4": {
         "Introspekt\\": "src/"
      }
   },
   "scripts": {
      "test": "phpunit ./test",
      "coverage": "XDEBUG_MODE=coverage phpunit --coverage-text ./test"
   }
}